# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
TEMPERATURE=0.7
MAX_TOKENS=2000

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
LOG_LEVEL=DEBUG

# LangGraph Configuration
LANGGRAPH_CHECKPOINT_TYPE=memory
LANGGRAPH_CHECKPOINT_PATH=./data/checkpoints
LANGGRAPH_DEBUG=true

# Memory Configuration (Simple file-based for hackathon)
MEMORY_TYPE=file
MEMORY_PATH=./data/memory
MEMORY_SEARCH_LIMIT=5

# UI Configuration (Optional)
UI_ENABLED=true
UI_PORT=8501
UI_HOST=0.0.0.0

# File Processing Configuration
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=pdf,docx,txt,pptx
UPLOAD_DIRECTORY=./uploads

# Output Configuration
OUTPUT_DIRECTORY=./outputs
EXPORT_FORMATS=csv,json,html,pdf

# Voice Processing (Optional)
WHISPER_MODEL=base
ENABLE_VOICE_INPUT=false

# Workflow Configuration
DEFAULT_WORKFLOW_TIMEOUT=300  # 5 minutes
MAX_AGENT_RETRIES=3
ENABLE_PARALLEL_PROCESSING=false

# Company/OKR Configuration (for demo purposes)
DEFAULT_COMPANY_OKRS="Improve AI/ML skills,Enhance data literacy,Build technical leadership,Foster innovation culture"
DEFAULT_INDUSTRY="Technology"

# Development/Testing
MOCK_LLM_RESPONSES=false
CACHE_LLM_RESPONSES=true
CACHE_DURATION=3600

# Offline LLM Configuration
OFFLINE_LLM_ENABLED=true
# OFFLINE_LLM_MODEL=openai/gpt-oss-20b

OFFLINE_LLM_DEVICE=auto

# TTS Configuration
TTS_ENABLED=true
TTS_DEFAULT_ENGINE=pyttsx3
TTS_SPEED=1.0
TTS_CLEANUP_HOURS=24

# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./data/learnerexpert.db
DATABASE_ECHO=false